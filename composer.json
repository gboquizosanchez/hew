{
    "name": "gboquizosanchez/hew",
    "description": "Schema as source of truth for Laravel migrations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-laravel": "^4",
        "phpstan/phpstan": "^2.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Boquizo\\Hew\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Boquizo\\Hew\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Boquizo\\Hew\\HewServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
